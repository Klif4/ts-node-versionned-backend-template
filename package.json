  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "vitest-mock-extended": "^2.0.2"
  }
