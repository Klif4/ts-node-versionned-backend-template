{
  "name": "ts-node-versionned-backend-template",
  "version": "1.0.0",
  "description": "Node TypeScript backend template with hexagonal architecture",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test:unit": "vitest run",
